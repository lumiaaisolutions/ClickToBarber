# ========================================================================
# ClickToBarber API — variables de entorno
# ========================================================================
# Copia este archivo a `.env` y rellena con valores reales para cada entorno.
# NUNCA commitees `.env`. NUNCA pongas secrets reales aquí.
#
# Producción (Hostinger CageFS):
#   - DB_CONNECTION=pgsql con Postgres externo (Supabase / Neon / Railway)
#   - CACHE_STORE=database, QUEUE_CONNECTION=database, SESSION_DRIVER=database
#     (Hostinger CageFS no permite Redis)

# ---- App ----
APP_NAME=ClickToBarber
APP_ENV=local                 # local | staging | production
APP_KEY=                      # php artisan key:generate
APP_DEBUG=true                # false en production
APP_TIMEZONE=America/Mexico_City
APP_URL=http://localhost:8000
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_TRANSLATE=es
APP_FAKER_LOCALE=es_MX
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug               # warning | error en production
LOG_JSON=false                # true en prod para Sentry/Loki/Datadog

# ---- Database ----
# Dev: SQLite (zero-fricción). Prod: MySQL managed de Hostinger.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=u221820910_clicktobarber
# DB_USERNAME=u221820910_clicktobarber
# DB_PASSWORD=

# ---- Sesión / cookies ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=        # true en production (HTTPS)
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# ---- Sanctum ----
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SANCTUM_EXPIRATION=10080      # 7 días
SANCTUM_TOKEN_PREFIX=ctb_     # para detectar leaks

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000
PUBLIC_BOOKING_BASE_URL=      # default = FRONTEND_URL

# ---- Broadcast / Queue / Cache (Hostinger CageFS: database driver) ----
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=ctb_

# ---- Redis (DESHABILITADO en producción Hostinger CageFS) ----
# Si en algún momento migras a un VPS con Redis disponible, cambia los
# drivers de arriba y rellena estas vars.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# ---- Mail ----
# Dev: log. Prod Hostinger SMTP. Ver docs/runbook/setup-mail-hostinger.md
MAIL_MAILER=log               # smtp en producción
MAIL_SCHEME=null
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=                # tu buzón hostinger
MAIL_PASSWORD=                # password del buzón
MAIL_FROM_ADDRESS="no-reply@clicktobarber.lumiaaisolutions.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ENCRYPTION=ssl

# ========================================================================
# Integraciones externas
# ========================================================================

# ---- WhatsApp ----
# Drivers: 'wa_link' (deep-link wa.me, sin aprobación Meta) | 'cloud' (Cloud API real)
# El servicio detecta automáticamente: si WHATSAPP_DRIVER=cloud pero faltan
# WHATSAPP_PHONE_ID + WHATSAPP_TOKEN, cae a wa_link. Anti no-show automatizado
# requiere driver=cloud (con wa_link solo se generan links manuales).
WHATSAPP_DRIVER=wa_link
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_API_VERSION=v20.0
META_WEBHOOK_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# Plantillas aprobadas (sólo si driver=cloud)
WHATSAPP_TPL_CONFIRMATION=appointment_confirmation
WHATSAPP_TPL_REMINDER_24H=appointment_reminder_24h
WHATSAPP_TPL_REMINDER_2H=appointment_reminder_2h_with_buttons
WHATSAPP_TPL_CANCELLED=appointment_cancelled_no_response

# ---- Stripe (Cashier) ----
STRIPE_DRIVER=mock            # mock | stripe
STRIPE_KEY=                   # pk_test_... | pk_live_...
STRIPE_SECRET=                # sk_test_... | sk_live_...
STRIPE_WEBHOOK_SECRET=        # whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/checkout/success
STRIPE_CANCEL_URL=http://localhost:3000/precios

# Price IDs (uno por plan + ciclo). Los creas en Stripe Dashboard.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=
STRIPE_PRICE_PREMIUM=

# ---- MercadoPago (apagado por defecto en ClickToBarber) ----
BILLING_MERCADOPAGO_ENABLED=false
MERCADOPAGO_DRIVER=mock
MERCADOPAGO_TOKEN=

# ---- Twilio Voice (fallback anti no-show, opcional) ----
TWILIO_DRIVER=log
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ---- Sentry ----
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

# ========================================================================
# Resiliencia y rate limiting (DB-backed locks reemplazan Redis)
# ========================================================================

CB_DEFAULT_FAILURE_THRESHOLD=5
CB_DEFAULT_FAILURE_WINDOW=60
CB_DEFAULT_COOLDOWN=30
CB_DEFAULT_SUCCESS_THRESHOLD=2

RATE_LIMIT_GLOBAL_PER_MIN=100
THROTTLE_LOGIN_ATTEMPTS=5
THROTTLE_LOGIN_DECAY=1
THROTTLE_BOOKING_ATTEMPTS=10
THROTTLE_BOOKING_DECAY=1

# Magic links onboarding
MAGIC_LINK_TTL=1440           # 24h

# Trial manual (sin Stripe) — patrón ClickToEat
TRIAL_MANUAL_DAYS=15

# Vite / frontend env share
VITE_APP_NAME="${APP_NAME}"
