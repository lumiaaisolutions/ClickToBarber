APP_NAME=BarberPro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Mexico_City
APP_URL=http://localhost:8000
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_MX
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — SQLite por defecto (zero-fricción dev). Cambia a pgsql para multi-tenant con RLS.
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5433
# DB_DATABASE=barberpro
# DB_USERNAME=barberpro
# DB_PASSWORD=barberpro_dev

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

# Redis (Circuit Breaker, rate limit). Si no corre Docker, deja vacío y se usará array driver.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# Mail (Mailpit en :8025)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hola@barberpro.test"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum / Frontend
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Integraciones externas (mock/log por defecto en local)
WHATSAPP_DRIVER=log
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
TWILIO_DRIVER=log
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
STRIPE_DRIVER=mock
STRIPE_KEY=
STRIPE_SECRET=
MERCADOPAGO_DRIVER=mock
MERCADOPAGO_TOKEN=

# Circuit Breaker
CB_DEFAULT_FAILURE_THRESHOLD=5
CB_DEFAULT_FAILURE_WINDOW=60
CB_DEFAULT_COOLDOWN=30
CB_DEFAULT_SUCCESS_THRESHOLD=2

# Rate limit
RATE_LIMIT_GLOBAL_PER_MIN=100

VITE_APP_NAME="${APP_NAME}"
