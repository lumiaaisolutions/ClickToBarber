# ========================================================================
# LUMIA backend — variables de entorno
# ========================================================================
# Copia este archivo a `.env` y rellena con valores reales para cada entorno.
# NUNCA cometear .env. NUNCA poner secrets reales en este archivo.

# ---- App ----
APP_NAME=LUMIA
APP_ENV=local                 # local | staging | production
APP_KEY=                      # generar con: php artisan key:generate
APP_DEBUG=true                # SIEMPRE false en production
APP_TIMEZONE=America/Mexico_City
APP_URL=http://localhost:8000
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
# Idioma fuerza para validation messages (cargado desde lang/es/validation.php)
APP_TRANSLATE=es
APP_FAKER_LOCALE=es_MX
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug               # warning | error en production

# ---- Database ----
# SQLite por defecto (zero-fricción dev). Cambia a pgsql para multi-tenant con RLS.
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=lumia
# DB_USERNAME=lumia
# DB_PASSWORD=                # gestor de secrets

# ---- Sesión / cookies ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true          # true en production
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=        # true en production (HTTPS only)
SESSION_SAME_SITE=lax         # lax | strict | none
SESSION_HTTP_ONLY=true

# ---- Sanctum ----
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SANCTUM_EXPIRATION=10080      # minutos (10080 = 7 días)
SANCTUM_TOKEN_PREFIX=         # opcional: ej. "lumia_" para detectar leaks

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000

# ---- Broadcast / Queue / Cache ----
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database     # redis en production
CACHE_STORE=file              # redis en production
CACHE_PREFIX=

# ---- Redis (Circuit Breaker, rate limit, queues, cache) ----
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# ---- Mail (Mailpit en :8025 dev) ----
MAIL_MAILER=log               # smtp | resend | postmark en production
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hola@lumia.test"
MAIL_FROM_NAME="${APP_NAME}"

# ========================================================================
# Integraciones externas — gestor de secrets en production
# ========================================================================

# ---- WhatsApp Cloud API (Meta) ----
# Driver: log (mock dev) | meta (HTTP a graph.facebook.com)
WHATSAPP_DRIVER=log
WHATSAPP_PHONE_ID=            # ID del número verificado en Meta
WHATSAPP_TOKEN=               # Bearer token permanente del Business Account
WHATSAPP_API_VERSION=v20.0
META_WEBHOOK_SECRET=          # secret compartido para HMAC de /api/webhooks/whatsapp
META_WEBHOOK_VERIFY_TOKEN=    # token de verificación inicial del webhook

# Plantillas aprobadas (nombres exactos en Meta)
WHATSAPP_TPL_CONFIRMATION=appointment_confirmation
WHATSAPP_TPL_REMINDER_24H=appointment_reminder_24h
WHATSAPP_TPL_REMINDER_2H=appointment_reminder_2h_with_buttons
WHATSAPP_TPL_CANCELLED=appointment_cancelled_no_response

# ---- Stripe ----
# Driver: mock (siempre éxito) | stripe (HTTP real)
STRIPE_DRIVER=mock
STRIPE_KEY=                   # publishable: pk_test_... | pk_live_...
STRIPE_SECRET=                # secret: sk_test_... | sk_live_...
STRIPE_WEBHOOK_SECRET=        # whsec_... para HMAC de /api/webhooks/stripe
STRIPE_SUCCESS_URL=http://localhost:3000/checkout/success
STRIPE_CANCEL_URL=http://localhost:3000/precios

# Price IDs de Stripe (uno por plan + ciclo)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# ---- MercadoPago ----
MERCADOPAGO_DRIVER=mock
MERCADOPAGO_TOKEN=

# ---- Twilio Voice (fallback de no-show) ----
TWILIO_DRIVER=log
TWILIO_SID=
TWILIO_TOKEN=                 # también se usa como secret de HMAC en webhook
TWILIO_FROM=                  # número emisor

# ========================================================================
# Resiliencia y rate limiting
# ========================================================================

# Circuit Breaker (Redis con scripts Lua atómicos)
CB_DEFAULT_FAILURE_THRESHOLD=5
CB_DEFAULT_FAILURE_WINDOW=60
CB_DEFAULT_COOLDOWN=30
CB_DEFAULT_SUCCESS_THRESHOLD=2

# Rate limit global (req/min/IP). Endpoints específicos tienen sus propios límites.
RATE_LIMIT_GLOBAL_PER_MIN=100
THROTTLE_LOGIN_ATTEMPTS=5
THROTTLE_LOGIN_DECAY=1
THROTTLE_BOOKING_ATTEMPTS=10
THROTTLE_BOOKING_DECAY=1

# Magic links (onboarding email tras pago Stripe)
MAGIC_LINK_TTL=1440           # minutos (1440 = 24h)

# ---- Vite (frontend deploys que comparten env) ----
VITE_APP_NAME="${APP_NAME}"
